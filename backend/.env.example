# KavachIQ Backend Configuration

# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kavachiq
DB_USER=postgres
DB_PASSWORD=your_secure_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# CVE & Threat Intelligence
NIST_CVE_API=https://services.nvd.nist.gov/rest/json/cves/2.0
SHODAN_API_KEY=your_shodan_api_key_optional
IPQUALITYSCORE_API_KEY=your_ipqs_api_key_optional

# Google Docs Integration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_google_private_key_base64_encoded
GOOGLE_DOCS_FOLDER_ID=your_google_drive_folder_id

# Security Scanning
ENABLE_MALWARE_CHECK=true
ENABLE_SSL_CHECK=true
ENABLE_CVE_SCAN=true
SCAN_TIMEOUT=30000

# CORS
CORS_ORIGIN=http://localhost:3000,https://kavachiq.com

# Email/Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
