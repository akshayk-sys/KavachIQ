FROM node:18-alpine AS builder

ARG VITE_BASE_URL=/
ARG VITE_APP_BASENAME=/

WORKDIR /app

COPY frontend/package*.json ./

RUN npm ci

COPY frontend ./

RUN VITE_BASE_URL=$VITE_BASE_URL VITE_APP_BASENAME=$VITE_APP_BASENAME npm run build

# Production stage
FROM node:18-alpine

WORKDIR /app

RUN npm install -g serve

COPY --from=builder /app/dist ./dist

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
